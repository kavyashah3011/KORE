# =============================================================================
# KORE Configuration - Using FREE Ollama (No API Costs!)
# =============================================================================
# Copy this file to .env and customize for your setup

# =============================================================================
# OLLAMA CONFIGURATION (Free, runs locally on your computer)
# =============================================================================

# Model to use from Ollama
# Popular models: mistral, llama2, neural-chat, orca-mini, zephyr
# Download: ollama pull mistral
OLLAMA_MODEL=mistral

# Ollama server URL (default: localhost:11434)
# Change if Ollama runs on a different machine
OLLAMA_BASE_URL=http://localhost:11434

# Temperature settings (0.0 = focused, 1.0 = creative)
OLLAMA_TEMP_LOW=0.1
OLLAMA_TEMP_MED=0.3

# =============================================================================
# YOUR GOAL - What KORE should work on
# =============================================================================
# Examples:
# - "Create a business plan for a fintech startup"
# - "Research best practices for remote team management"
# - "Design an architecture for a scalable API"

KORE_GOAL=Research the current state of AI agent frameworks in 2025, create an actionable adoption plan for a mid-sized tech startup, and produce a quality-reviewed final report.

# =============================================================================
# OPTIONAL: Alternative API Configuration
# =============================================================================
# If you want to use Groq instead of Ollama (also has free tier):
# Get free API key: https://console.groq.com
# Then use .env.groq configuration

# GROQ_API_KEY=your-groq-key-here
