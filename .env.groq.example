# =============================================================================
# KORE Configuration - Using FREE Groq API (Cloud Alternative to Ollama)
# =============================================================================
# Copy this to .env if you prefer Groq over Ollama
# Get free API key: https://console.groq.com/keys
# Free tier: 500+ requests/day

# =============================================================================
# GROQ CONFIGURATION (Free cloud LLM API)
# =============================================================================

# Get your free API key from https://console.groq.com/keys
GROQ_API_KEY=your-free-groq-api-key-here

# Available models on Groq (check their docs for latest):
# - mixtral-8x7b-32768 (very fast, good quality)
# - llama2-70b-4096 (powerful)
# - gemma-7b-it (lightweight)
GROQ_MODEL=mixtral-8x7b-32768

# =============================================================================
# YOUR GOAL - What KORE should work on
# =============================================================================

KORE_GOAL=Research the current state of AI agent frameworks in 2025, create an actionable adoption plan for a mid-sized tech startup, and produce a quality-reviewed final report.

# =============================================================================
# USAGE
# =============================================================================
# 1. Install: pip install -r requirements.txt
# 2. Get free API key from https://console.groq.com/keys
# 3. Copy this file to .env and add your API key
# 4. Update agents/base.py to use Groq instead of Ollama (see code below)
# 5. Run: python main.py

